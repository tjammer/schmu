-- standard case
fun match_opt(p) {
  match p {
    Some(thing) -> thing
    None -> 0
  }
}
match_opt(Some(1)) |> fmt/fun i { println(int, i) }
match_opt(None) |> fmt/fun i { println(int, i) }

-- switch ctors
fun opt_match(p) {match p { None -> 0; Some(thing) -> thing}}

opt_match(Some(1)) |> fmt/fun i { println(int, i) }
opt_match(None) |> fmt/fun i { println(int, i) }

-- some, catchall
fun some_all( p){
  match p {
    Some(thing) -> thing
    _ -> 0
  }
}
some_all(Some(1)) |> fmt/fun i { println(int, i) }
some_all(None) |> fmt/fun i { println(int, i) }

fun none_all(p) {match p {None -> 0 | _ -> 1}}

none_all(Some(1)) |> fmt/fun i { println(int, i) }
let none_int : option[int] = None
none_all(none_int) |> fmt/fun i { println(int, i) }
