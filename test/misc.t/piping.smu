external printi : fun (int) -> unit = "Printi"

-- pipe into normal function
1 |> fun x {x + 1} |> printi

Some(1)
|> fun x {match x {
  Some(a) -> a
  None -> 0
}}
|> printi

-- pipe field accessor (this isn't supported anymore, but works naturally with .x)
type foo = {x : int}
{x = 1}.x |> printi()
println("")
fmt/(println(int, 10))
string/of_array(['a', 'b', 'c']) |> string/get(1) |> fun i { fmt/(println(u8, i)) }
